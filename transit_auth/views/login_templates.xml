<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="login" inherit_id="web.login" name="TransitOps Login">
        <xpath expr="//form[contains(@t-attf-class, 'oe_login_form')]" position="before">
            <div class="to-role-section">
                <label class="to-role-label" for="role_selected">Select Role</label>
                <div class="to-role-select-wrapper">
                    <select name="role_selected" id="role_selected" class="form-control">
                        <option value="fleet_manager">Fleet Manager</option>
                        <option value="driver">Driver</option>
                        <option value="safety_officer">Safety Officer</option>
                        <option value="financial_analyst">Financial Analyst</option>
                    </select>
                    <span class="to-role-select-arrow">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
                    </span>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
