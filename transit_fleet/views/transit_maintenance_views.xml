<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="transit_maintenance_view_form" model="ir.ui.view">
        <field name="name">transit.maintenance.form</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" string="Start Maintenance" type="object"
                            class="oe_highlight" invisible="state != 'draft'"
groups="transit_base.group_fleet_manager,transit_base.group_safety_officer"/>
                     <button name="action_close" string="Close Maintenance" type="object"
                             class="oe_highlight" invisible="state != 'in_progress'"
                             groups="transit_base.group_fleet_manager,transit_base.group_safety_officer"/>
                     <button name="action_cancel" string="Cancel" type="object"
                             invisible="state not in ('draft', 'in_progress')"
                             groups="transit_base.group_fleet_manager,transit_base.group_safety_officer"/>
                     <button name="action_reset_draft" string="Reset to Draft" type="object"
                             invisible="state != 'cancelled'"
                             groups="transit_base.group_fleet_manager,transit_base.group_safety_officer"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Maintenance Title"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Maintenance Details">
                            <field name="vehicle_id"/>
                            <field name="maintenance_type"/>
                            <field name="mechanic"/>
                        </group>
                        <group string="Schedule &amp; Cost">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="cost"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"
                                   placeholder="Describe the maintenance work..."/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Additional notes..."/>
                        </page>
                        <page string="Previous Maintenance History" name="previous_maintenance_history">
                            <field name="previous_maintenance_ids" readonly="1">
                                <list>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="name"/>
                                    <field name="maintenance_type"/>
                                    <field name="mechanic"/>
                                    <field name="cost"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'done'"
                                           decoration-info="state == 'in_progress'"
                                           decoration-danger="state == 'cancelled'"
                                           decoration-muted="state == 'draft'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="transit_maintenance_view_tree" model="ir.ui.view">
        <field name="name">transit.maintenance.tree</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'done'"
                  decoration-info="state == 'in_progress'"
                  decoration-danger="state == 'cancelled'"
                  decoration-muted="state == 'draft'">
                <field name="vehicle_id"/>
                <field name="name"/>
                <field name="maintenance_type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="cost"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'in_progress'"
                       decoration-danger="state == 'cancelled'"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="transit_maintenance_view_search" model="ir.ui.view">
        <field name="name">transit.maintenance.search</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="mechanic"/>
                <filter string="Draft" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="In Progress" name="in_progress"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="done"
                        domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="cancelled"
                        domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <group>
                    <filter string="Vehicle" name="group_by_vehicle"
                            context="{'group_by': 'vehicle_id'}"/>
                    <filter string="State" name="group_by_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Maintenance Type" name="group_by_type"
                            context="{'group_by': 'maintenance_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_transit_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">transit.maintenance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="transit_maintenance_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No maintenance records yet.
            </p>
            <p>
                Create a maintenance record to track vehicle service and repairs.
            </p>
        </field>
    </record>
</odoo>
