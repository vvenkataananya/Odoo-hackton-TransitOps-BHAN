<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="transit_vehicle_view_form" model="ir.ui.view">
        <field name="name">transit.vehicle.form</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_trips" type="object" class="oe_stat_button"
                                icon="fa-road">
                            <field name="trip_count" widget="statinfo" string="Trips"/>
                        </button>
                        <button name="action_view_maintenance" type="object" class="oe_stat_button"
                                icon="fa-wrench">
                            <field name="active_maintenance_count" widget="statinfo" string="Maintenance"/>
                        </button>
                        <button name="action_view_maintenance" type="object" class="oe_stat_button"
                                icon="fa-money">
                            <field name="total_maintenance_cost" widget="statinfo" string="Maint. Cost"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="registration_number"/>
                        <h1>
                            <field name="registration_number" placeholder="Registration Number"/>
                        </h1>
                    </div>
                    <notebook>
                        <page string="General Info" name="general_info">
                            <group>
                                <group string="Vehicle Details">
                                    <field name="vehicle_name"/>
                                    <field name="vehicle_type_id"/>
                                    <field name="fuel_type"/>
                                    <field name="status"/>
                                </group>
                                <group string="Additional Info">
                                    <field name="year_manufacture"/>
                                    <field name="color"/>
                                    <field name="active"/>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                </group>
                            </group>
                        </page>
                        <page string="Technical" name="technical">
                            <group>
                                <group string="Capacity &amp; Usage">
                                    <field name="max_load_capacity"/>
                                    <field name="current_odometer"/>
                                    <field name="acquisition_cost"/>
                                </group>
                            </group>
                        </page>
                        <page string="Location" name="location">
                            <group>
                                <group string="Coordinates">
                                    <field name="latitude"/>
                                    <field name="longitude"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="transit_vehicle_view_tree" model="ir.ui.view">
        <field name="name">transit.vehicle.tree</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <list decoration-success="status == 'available'"
                  decoration-info="status == 'on_trip'"
                  decoration-warning="status == 'in_shop'"
                  decoration-muted="status == 'retired'">
                <field name="registration_number"/>
                <field name="vehicle_name"/>
                <field name="vehicle_type_id"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'available'"
                       decoration-info="status == 'on_trip'"
                       decoration-warning="status == 'in_shop'"
                       decoration-muted="status == 'retired'"/>
                <field name="max_load_capacity"/>
                <field name="current_odometer"/>
            </list>
        </field>
    </record>

    <record id="transit_vehicle_view_search" model="ir.ui.view">
        <field name="name">transit.vehicle.search</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <search>
                <field name="registration_number"/>
                <field name="vehicle_name"/>
                <field name="vehicle_type_id"/>
                <separator/>
                <filter string="Available" name="available"
                        domain="[('status', '=', 'available')]"/>
                <filter string="On Trip" name="on_trip"
                        domain="[('status', '=', 'on_trip')]"/>
                <filter string="In Shop" name="in_shop"
                        domain="[('status', '=', 'in_shop')]"/>
                <filter string="Retired" name="retired"
                        domain="[('status', '=', 'retired')]"/>
                <separator/>
                <group>
                    <filter string="Vehicle Type" name="group_by_type"
                            context="{'group_by': 'vehicle_type_id'}"/>
                    <filter string="Status" name="group_by_status"
                            context="{'group_by': 'status'}"/>
                    <filter string="Fuel Type" name="group_by_fuel_type"
                            context="{'group_by': 'fuel_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_transit_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="transit_vehicle_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No vehicles registered yet.
            </p>
            <p>
                Register your first vehicle to start managing your fleet.
            </p>
        </field>
    </record>
</odoo>
