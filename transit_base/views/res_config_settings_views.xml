<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.transit_base</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="TransitOps" string="TransitOps" name="transit_base" groups="base.group_system">
                    <block title="Fleet Settings" name="transit_fleet_settings">
                        <setting id="transit_fuel_cost_setting">
                            <label for="fuel_cost_per_liter"/>
                            <div class="text-muted">
                                Default cost per liter of fuel for trip calculations.
                            </div>
                            <field name="fuel_cost_per_liter"/>
                        </setting>
                        <setting id="transit_license_reminder_setting">
                            <label for="license_expiry_reminder_days"/>
                            <div class="text-muted">
                                Number of days before a driver license expires to send a reminder.
                            </div>
                            <field name="license_expiry_reminder_days"/>
                        </setting>
                    </block>
                    <block title="External Services" name="transit_external_services">
                        <setting id="transit_weather_api_setting">
                            <label for="weather_api_key"/>
                            <div class="text-muted">
                                API key for OpenWeatherMap to fetch weather data for trip planning.
                            </div>
                            <field name="weather_api_key" password="True"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
