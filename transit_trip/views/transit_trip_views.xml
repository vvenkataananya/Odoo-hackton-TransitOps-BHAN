<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="transit_trip_view_form" model="ir.ui.view">
        <field name="name">transit.trip.form</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_dispatch" string="Dispatch Trip" type="object"
                            class="oe_highlight" invisible="state != 'draft'"
                            groups="transit_base.group_fleet_manager"/>
                    <button name="action_complete" string="Complete Trip" type="object"
                            class="oe_highlight" invisible="state != 'dispatched'"
                            groups="transit_base.group_fleet_manager"/>
                    <button name="action_cancel" string="Cancel Trip" type="object"
                            invisible="state not in ('draft', 'dispatched')"
                            groups="transit_base.group_fleet_manager"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'"
                            groups="transit_base.group_fleet_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,dispatched,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_fuel_logs" type="object" class="oe_stat_button"
                                icon="fa-tint">
                            <field name="total_fuel_cost" widget="statinfo" string="Fuel Cost"/>
                        </button>
                        <button name="action_view_expenses" type="object" class="oe_stat_button"
                                icon="fa-money">
                            <field name="total_trip_expenses" widget="statinfo" string="Expenses"/>
                        </button>
                        <div class="oe_stat_button" icon="fa-calculator">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value" name="operational_cost"/>
                                <span class="o_stat_text">Op. Cost</span>
                            </div>
                        </div>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Trip Name"/>
                        </h1>
                        <field name="priority" widget="priority"/>
                    </div>
                    <group>
                        <group>
                            <field name="source"/>
                            <field name="destination"/>
                            <div class="d-flex align-items-center gap-2">
                                <button name="action_fetch_route_distance" string=""
                                        title="Fetch Coordinates and Distance"
                                        type="object" icon="fa-refresh" class="btn-secondary"
                                        invisible="not source or not destination"/>
                                <button name="action_open_route_map" string=""
                                        title="Open Route Map"
                                        type="object" icon="fa-map-marker" class="btn-secondary"
                                        invisible="not source or not destination"/>
                                <span class="text-muted">Map Distance</span>
                                <field name="map_distance_km" nolabel="1" readonly="1" class="oe_inline"/>
                            </div>
                        </group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="driver_id"/>
                            <field name="cargo_weight"/>
                            <field name="planned_distance"/>
                        </group>
                    </group>
                    <group string="Smart Dispatch Readiness">
                        <group>
                            <field name="dispatch_readiness_score" readonly="1"/>
                            <field name="dispatch_decision" widget="badge" readonly="1"
                                   decoration-success="dispatch_decision == 'ready'"
                                   decoration-warning="dispatch_decision == 'warning'"
                                   decoration-danger="dispatch_decision == 'blocked'"/>
                        </group>
                        <group>
                            <field name="dispatch_warning" readonly="1" nolabel="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Trip Details" name="trip_details">
                            <group>
                                <group string="Completion Info">
                                    <field name="actual_distance"/>
                                    <field name="final_odometer" readonly="state != 'dispatched'"/>
                                    <field name="fuel_consumed" readonly="state != 'dispatched'"/>
                                    <field name="fuel_cost_per_liter" readonly="state != 'dispatched'"/>
                                    <field name="total_fuel_price" readonly="1"/>
                                </group>
                                <group string="Dates &amp; Location">
                                    <field name="dispatch_date"/>
                                    <field name="completion_date"/>
                                </group>
                            </group>
                            <group string="Route Coordinates">
                                <group string="Source">
                                    <field name="source_latitude" readonly="1"/>
                                    <field name="source_longitude" readonly="1"/>
                                </group>
                                <group string="Destination">
                                    <field name="destination_latitude" readonly="1"/>
                                    <field name="destination_longitude" readonly="1"/>
                                </group>
                            </group>
                            <group string="Metrics">
                                <group>
                                    <field name="fuel_efficiency" readonly="1"/>
                                    <field name="duration_hours" readonly="1"/>
                                    <field name="operational_cost" readonly="1"/>
                                    <field name="map_distance_source" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="transit_trip_view_tree" model="ir.ui.view">
        <field name="name">transit.trip.tree</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'dispatched'"
                  decoration-success="state == 'completed'"
                  decoration-danger="state == 'cancelled'"
                  decoration-warning="state == 'draft'">
                <field name="name"/>
                <field name="source"/>
                <field name="destination"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'dispatched'"
                       decoration-success="state == 'completed'"
                       decoration-danger="state == 'cancelled'"
                       decoration-warning="state == 'draft'"/>
                <field name="priority" widget="priority"/>
                <field name="planned_distance"/>
                <field name="cargo_weight"/>
                <field name="dispatch_date"/>
            </list>
        </field>
    </record>

    <record id="transit_trip_view_search" model="ir.ui.view">
        <field name="name">transit.trip.search</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="source"/>
                <field name="destination"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Dispatched" name="dispatched" domain="[('state','=','dispatched')]"/>
                <filter string="Completed" name="completed" domain="[('state','=','completed')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state','=','cancelled')]"/>
                <separator/>
                <group>
                    <filter string="State" name="group_by_state" context="{'group_by':'state'}"/>
                    <filter string="Vehicle" name="group_by_vehicle" context="{'group_by':'vehicle_id'}"/>
                    <filter string="Driver" name="group_by_driver" context="{'group_by':'driver_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="transit_trip_action" model="ir.actions.act_window">
        <field name="name">Trips</field>
        <field name="res_model">transit.trip</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="transit_trip_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first trip
            </p>
            <p>
                Dispatch vehicles and drivers for trips.
            </p>
        </field>
    </record>
</odoo>
